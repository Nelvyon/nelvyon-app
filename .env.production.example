# NELVYON OS — variables de producción (Railway → https://nelvyon.com)
# Copia a Railway → Project → Variables. No commitear valores reales.

# ─── Core ─────────────────────────────────────────────────────────────────────
# Postgres Supabase (service role / pooler). NUNCA uses anon key aquí.
DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

NEXT_PUBLIC_APP_URL=https://nelvyon.com

# Auth (cookies / API). Mínimo 32 caracteres: openssl rand -base64 32
JWT_SECRET=

# OpenAI — agentes OS (LlmClient)
OPENAI_API_KEY=sk-

# ─── Supabase (cliente navegador) ───────────────────────────────────────────
# Alias documentados; en código se usan NEXT_PUBLIC_*.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor (opcional REST admin; pool usa DATABASE_URL)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Paddle Billing ─────────────────────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_STARTER=
NEXT_PUBLIC_PADDLE_PRICE_PRO=
NEXT_PUBLIC_PADDLE_PRICE_AGENCY=

# ─── OAuth (MIG 294–297) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://nelvyon.com/api/oauth/google/callback

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://nelvyon.com/api/oauth/meta/callback

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=https://nelvyon.com/api/oauth/tiktok/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://nelvyon.com/api/oauth/linkedin/callback

# 32 bytes hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY=

# Google Ads API (lectura/ejecución campañas)
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Email (AWS SES) ────────────────────────────────────────────────────────
# En código: SES_ACCESS_KEY_ID / SES_SECRET_ACCESS_KEY (alias Railway abajo).
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_REGION=eu-west-1
SES_FROM_EMAIL=no-reply@nelvyon.com

# ─── Observabilidad ─────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=nelvyon
SENTRY_PROJECT=nelvyon-web

LOG_LEVEL=info

# ─── Redis / cola async (Upstash) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ASYNC_QUEUE_ENABLED=true
MAX_CONCURRENT_JOBS=3

# ─── Railway / runtime ──────────────────────────────────────────────────────
# PORT lo inyecta Railway. HOSTNAME=0.0.0.0 va en startCommand de railway.toml.
CRON_SECRET=
