{
  "name": "@nelvyon/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next dev",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "build:prod": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "start": "node server.js",
    "start:prod": "node server.js",
    "migrate": "tsx ../../backend/db/migrate.ts",
    "migrate:prod": "tsx ./scripts/migrate-prod.ts",
    "validate:saas-deals-migrations": "tsx ./scripts/validate-saas-deals-migrations.ts",
    "validate:os-core-migrations": "tsx ./scripts/validate-os-core-migrations.ts",
    "validate:staging": "tsx ./scripts/run-staging-validators.ts",
    "validate:os-clients-backfill": "tsx ./scripts/validate-os-clients-backfill.ts",
    "os:clients-backfill": "tsx ../../backend/os-core/scripts/runOsClientsBackfill.ts",
    "os:projects-backfill": "tsx ../../backend/os-core/scripts/runOsProjectsBackfill.ts",
    "validate:os-projects-backfill": "tsx ./scripts/validate-os-projects-backfill.ts",
    "saas:validate-bridge": "tsx ../../backend/saas/scripts/validateTenantBridge.ts",
    "saas:crm-etl": "tsx ../../backend/saas/scripts/runCrmEtl.ts",
    "saas:deals-etl": "tsx ../../backend/saas/scripts/runDealsEtl.ts",
    "saas:billing-backfill": "tsx ../../backend/saas/scripts/runBillingSync.ts",
    "lint": "eslint .",
    "typecheck": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:saas": "playwright test --config playwright.saas.config.ts",
    "test:e2e:saas:local": "node ./scripts/run-saas-e2e-local.mjs",
    "test:e2e:staging": "playwright test -c playwright.staging.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "gate:prepush": "pnpm gate && pnpm test:e2e:saas:local",
    "test:smoke": "node ./scripts/run-smoke.mjs",
    "test:regression": "vitest run",
    "test:bot-evals": "vitest run src/features/helpbot/__tests__/engine.test.ts",
    "autonomous:simulate": "tsx ../../backend/autonomous/scripts/run-simulation.ts",
    "autonomous:phase-c": "tsx ../../backend/autonomous/scripts/run-phase-c.ts",
    "e2e:phase0": "node ../../scripts/e2e-phase0-prod.mjs",
    "autonomous:phase-f": "tsx ../../backend/autonomous/scripts/run-phase-f-pilot.ts",
    "autonomous:phase-g": "tsx ../../backend/autonomous/scripts/run-phase-g-staging.ts",
    "autonomous:phase-h": "tsx ../../backend/autonomous/scripts/run-phase-h-preview.ts",
    "autonomous:phase-i": "tsx ../../backend/autonomous/scripts/run-phase-i-deploy.ts",
    "autonomous:learning": "tsx ../../backend/autonomous/scripts/run-learning.ts",
    "autonomous:rank-templates": "tsx ../../backend/autonomous/scripts/run-rank-templates.ts",
    "autonomous:enrich-outcomes": "tsx ../../backend/autonomous/scripts/run-enrich-outcomes.ts",
    "autonomous:learning-refresh": "tsx ../../backend/autonomous/scripts/run-learning-refresh.ts",
    "gate": "pnpm typecheck && pnpm lint && pnpm test:smoke && pnpm test:bot-evals",
    "pwa:icons": "node ./scripts/generate-pwa-icons.mjs",
    "os:envato:login": "tsx ../../backend/os-agents/seeds/download-envato-browser.ts --login",
    "os:envato:browser": "tsx ../../backend/os-agents/seeds/download-envato-browser.ts --cdp",
    "os:envato:browser:lite": "tsx ../../backend/os-agents/seeds/download-envato-browser.ts --cdp --lite",
    "os:envato:mejores": "tsx ../../backend/os-agents/seeds/download-envato-browser.ts --cdp --lite --parallel 5 --batch-delay 10",
    "os:envato:full": "tsx ../../backend/os-agents/seeds/download-envato-browser.ts --cdp --parallel 2 --batch-delay 0",
    "os:envato:multi": "tsx ../../backend/os-agents/seeds/run-envato-multi-download.ts",
    "os:envato:market-bulk": "tsx ../../backend/os-agents/seeds/download-envato-market-bulk.ts",
    "os:envato:watch-download": "tsx ../../backend/os-agents/seeds/run-envato-watch-download.ts",
    "os:envato:index-os-full": "tsx ../../backend/os-agents/seeds/download-envato-seeds.ts --market --metadata-only --catalog all --os-full",
    "os:envato:index-million": "tsx ../../backend/os-agents/seeds/download-envato-seeds.ts --market --metadata-only --million-client",
    "os:envato:super-library": "tsx ../../backend/os-agents/seeds/run-envato-super-library.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0-beta.4",
    "@nelvyon/os-db": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.51.0",
    "@sentry/node": "^10.51.0",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.90.2",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@upstash/redis": "^1.36.2",
    "@xyflow/react": "^12.6.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotted-map": "^2.2.3",
    "fast-xml-parser": "^5.9.3",
    "fflate": "0.8.2",
    "framer-motion": "^12.38.0",
    "fumadocs-core": "16.9.1",
    "fumadocs-mdx": "^15.0.8",
    "fumadocs-ui": "16.9.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.22",
    "next": "^15.5.6",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "otpauth": "^9.5.1",
    "posthog-js": "^1.261.0",
    "posthog-node": "^5.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-fast-marquee": "^1.6.5",
    "react-use-measure": "^2.1.7",
    "recharts": "^2.15.4",
    "resend": "^4.8.0",
    "stripe": "17.7.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^6.0.2",
    "vite": "^7.1.12",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.184.1",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-loader": "^9.5.7",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
