# Next.js / OS job store — set when running with persistent OsJobStore (otherwise in-memory)
# MIG 279: use Supabase service_role Postgres URL (bypasses RLS). NEVER use anon key here.
DATABASE_URL=postgresql://postgres.[project-ref]:[SERVICE_ROLE_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt_from_supabase_dashboard>

# Supabase client (browser only — mig 279). Project: lezzkqpkxcoxqqcgohof
NEXT_PUBLIC_SUPABASE_URL=https://lezzkqpkxcoxqqcgohof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_public_key>
REDIS_URL=redis://localhost:6379

# Nelvyon OS cookie JWT — minimum 32 characters (required for /api/auth/* and protected /api/os/*)
JWT_SECRET=super-secret-key-min-32-chars-change-in-production

# OpenAI — required for real `web_premium` agent (LlmClient)
OPENAI_API_KEY=sk-...

# Stripe Billing (MIG 308 — reactivado; Paddle deshabilitado)
# SEO (MIG 287) — URL canónica y Search Console
NEXT_PUBLIC_APP_URL=https://nelvyon.com
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional absolute origin for Checkout return URLs (defaults to request URL origin)
# NEXT_PUBLIC_APP_URL=https://localhost:3000

# Railway cron — header x-cron-secret on GET /api/cron/status-check (every 5 min)
CRON_SECRET=<random_32_chars>

# Stripe — webhooks (/api/webhooks/stripe), checkout y API de suscripciones
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs mensuales (starter / pro / agency)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_AGENCY=price_...
# Alternativa: STRIPE_PRICE_STARTER_MONTHLY, STRIPE_PRICE_PRO_MONTHLY, etc.
# Cupón early adopter (opcional)
STRIPE_EARLY_ADOPTER_COUPON_ID=
# Portal de facturación (fallback si falla la API)
STRIPE_BILLING_PORTAL_FALLBACK=https://billing.stripe.com/p/login/test

# Workspace billing (Python API en :8000) — mismos Price IDs por plan/ciclo
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...

# ─── Railway Deploy ───────────────────────────────────────────────────────────
# Copy ALL variables below into Railway → Project → Variables
# DATABASE_URL          → Railway PostgreSQL plugin (auto-injected if linked)
# JWT_SECRET            → generate with: openssl rand -base64 32
# OPENAI_API_KEY        → platform.openai.com
# STRIPE_SECRET_KEY     → Stripe dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET → Stripe dashboard → Webhooks → signing secret
# STRIPE_PRICE_ID_*     → Stripe dashboard → Products → Prices (monthly)
# NEXT_PUBLIC_APP_URL   → https://nelvyon.com
# SES_ACCESS_KEY_ID     → AWS IAM user for SES (mig 258)
# SES_SECRET_ACCESS_KEY → AWS IAM user for SES (mig 258)
# SES_REGION            → us-east-1 (or eu-west-1)
# SES_FROM_EMAIL        → no-reply@nelvyon.com (must be verified in SES)
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_URL     → Upstash REST URL (rate limiting MIG 281, async queue MIG 282)
# UPSTASH_REDIS_REST_TOKEN / UPSTASH_REDIS_TOKEN → Upstash REST token
ASYNC_QUEUE_ENABLED=true
MAX_CONCURRENT_JOBS=3

# ─── PostHog Analytics (mig 277) — EU hosting (GDPR) ─────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=<phc_...>
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Optional server-side capture (/api/analytics)
POSTHOG_KEY=

# Google OAuth (MIG 294) — Ads, Search Console, Analytics 4
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://nelvyon.com/api/oauth/google/callback
# 32 bytes hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY=

# Meta OAuth (MIG 295) — Facebook / Instagram Ads
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://nelvyon.com/api/oauth/meta/callback

# F60 — Publicidad IA (Google Ads API + Meta Marketing API)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=https://nelvyon.com/api/oauth/tiktok/callback

# LinkedIn Ads OAuth (MIG 297)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://nelvyon.com/api/oauth/linkedin/callback

# Structured logging (MIG 289): debug | info | warn | error
LOG_LEVEL=info

# ─── Sentry Error Tracking (mig 272) ─────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=<dsn_de_sentry_dashboard>
SENTRY_ORG=nelvyon
SENTRY_PROJECT=nelvyon-web
SENTRY_AUTH_TOKEN=<auth_token_para_source_maps>

# ─── API Keys externas (NELVYON fallback, mig 263) ───────────────────────────
# Cifrado de keys por usuario en BD (AES-256-GCM). Usa al menos 32 caracteres en producción.
API_KEYS_ENCRYPTION_SECRET=<32_chars_random_string>
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
RUNWAY_API_KEY=
STABILITY_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_KEY=
# OPENAI_API_KEY ya está documentado arriba
