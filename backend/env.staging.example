# NELVYON OS — Staging Environment Configuration
# Copy this file to .env.staging and fill in the values

# ─── Core ───
ENVIRONMENT=staging
DEBUG=false
PORT=8000

# ─── Database ───
# Use a separate staging database (never share with production)
DATABASE_URL=postgresql+asyncpg://nelvyon_staging:password@staging-db.example.com:5432/nelvyon_staging

# ─── Authentication ───
JWT_SECRET_KEY=staging-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
# ENVIRONMENT=staging  # already set above — drives admin seed & demo safety
# SUPER_ADMIN_USER_IDS=  # optional comma-separated platform user IDs (delegates)
# ALLOW_ADMIN_BOOTSTRAP=false  # set true only if you need DB admin seed in prod-like env
#
# Mock JSON seed from backend/mock_data/*.json — never enabled by default in staging/production.
# ALLOW_MOCK_SEED=false
# MGX_IGNORE_INIT_DATA=  # if set (any value), skip mock seed even in dev/test
#
# SPA URL for post-OIDC redirect (no ?token=). If empty, same host as the API request is used.
# FRONTEND_APP_URL=https://app.example.com
# Optional cookie domain for shared parent (e.g. .example.com when API is api.example.com)
# SESSION_COOKIE_DOMAIN=
# Local HTTP dev only: FORCE_INSECURE_COOKIES=true  # allows Secure=false cookies over http

# ─── Stripe (Test Mode) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Sandbox) ───
SENDGRID_API_KEY=SG.test...
SENDGRID_FROM_EMAIL=staging@nelvyon.com

# ─── AI Services ───
# Use lower-cost models for staging
OPENAI_API_KEY=sk-...

# ─── Monitoring ───
# Enable verbose logging for staging
LOG_LEVEL=INFO

# ─── Rate Limiting ───
# Relaxed limits for staging testing
RATE_LIMIT_ENABLED=true