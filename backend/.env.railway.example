# NELVYON FastAPI — Railway (segundo servicio, Root Directory = backend/)
# Copia estas variables en Railway → Service (API) → Variables.
# En el servicio Next (apps/web) añade: NEXT_PUBLIC_API_BASE_URL=https://<tu-api>.up.railway.app

# ─── Obligatorias (mínimo viable) ───────────────────────────────────────────
ENVIRONMENT=production
PORT=8000

# Postgres (misma BD que Next o dedicada; asyncpg)
# Formato recomendado:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# JWT para sesiones FastAPI / API v1 (mín. 32 caracteres)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# AI Hub (orchestrator.py, generate-*, workspace AI)
# Puede ser OpenAI directo:
APP_AI_BASE_URL=https://api.openai.com/v1
APP_AI_KEY=sk-...

# ─── Muy recomendadas en producción ─────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Stripe (pagos workspace /api/v1/payment/*)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email transaccional
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@nelvyon.com

# CORS / redirects post-login OIDC
FRONTEND_APP_URL=https://nelvyon.com
PYTHON_BACKEND_URL=https://<tu-api>.up.railway.app

# SEO agents — Semrush + DataForSEO (datos reales en agentes seo_premium)
SEMRUSH_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Voz — ElevenLabs (síntesis TTS en outputs de agentes)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Opcionales ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...          # si algún módulo lee OPENAI directo
# ALLOW_ADMIN_BOOTSTRAP=false    # true solo para seed admin en prod (evitar)
# ADMIN_EMAIL=admin@nelvyon.com
# ADMIN_PASSWORD=
# ALLOW_MOCK_SEED=false
# MGX_IGNORE_INIT_DB=
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# RATE_LIMIT_ENABLED=true
# LOG_FORMAT=json
