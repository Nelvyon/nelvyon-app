# NELVYON OS — optional persistence (see backend/db/migrations/001_os_jobs.sql)
DATABASE_URL=postgresql://user:password@localhost:5432/nelvyon_os
REDIS_URL=redis://localhost:6379

# Cookie JWT for apps/web auth (min 32 chars)
JWT_SECRET=super-secret-key-min-32-chars-change-in-production

# OpenAI — required for real `web_premium` LLM pipeline (LlmClient)
OPENAI_API_KEY=sk-...

# Stripe (apps/web billing → OS)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=https://localhost:3000
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
RUNWAY_API_KEY=
MESHY_API_KEY=
ELEVENLABS_API_KEY=
